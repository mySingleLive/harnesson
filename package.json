{
  "name": "harnesson",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @harnesson/server dev & pnpm --filter @harnesson/web dev",
    "dev:web": "pnpm --filter @harnesson/web dev",
    "dev:server": "pnpm --filter @harnesson/server dev",
    "build": "pnpm --filter @harnesson/shared build && pnpm --filter @harnesson/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  }
}